  "git": {
    "branch_strategy": "feature-branches",
    "commit_style": "conventional",
    "liberal_commits": true,
    "squash_on_merge": "develop-only"
  },
  "context": {
    "scratchpad_pattern": "task-specific",
    "history_format": "iso8601",
    "track_learnings": true
  }
