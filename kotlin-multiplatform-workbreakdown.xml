<?xml version="1.0" encoding="UTF-8"?>
<workBreakdown>
  <project>
    <name>LegalEase Kotlin Multiplatform Reimplementation</name>
    <description>Comprehensive reimplementation of the LegalEase AI-powered regulatory navigation platform using Kotlin Multiplatform and Compose Multiplatform.</description>
    <version>1.0.0</version>
    <kotlinVersion>2.2+</kotlinVersion>
    <buildTool>gradle</buildTool>
    <targets>
      <target>wasmjs-frontend</target>
      <target>ktor-backend</target>
      <target>admin-area</target>
      <target>android-mobile-user</target>
      <target>android-mobile-admin</target>
      <target>ios-mobile-user</target>
      <target>ios-mobile-admin</target>
    </targets>
  </project>

  <antiCheatProtections>
    <protection name="test-verification">
      <description>All tests must pass before marking any task complete</description>
      <enforcement>mandatory</enforcement>
      <verification>automated</verification>
    </protection>
    <protection name="no-mocking-data">
      <description>No hardcoded or mocked data allowed - all data must come from real sources</description>
      <enforcement>mandatory</enforcement>
      <verification>code-review</verification>
    </protection>
    <protection name="no-disabled-tests">
      <description>Previous tests cannot be disabled or commented out</description>
      <enforcement>mandatory</enforcement>
      <verification>automated</verification>
    </protection>
    <protection name="code-review">
      <description>LLM must review code against requirements after each milestone</description>
      <enforcement>mandatory</enforcement>
      <verification>manual</verification>
    </protection>
    <protection name="no-over-engineering">
      <description>Code must not be over-engineered beyond requirements</description>
      <enforcement>mandatory</enforcement>
      <verification>code-review</verification>
    </protection>
    <protection name="common-code-requirement">
      <description>As much code as possible must be in Kotlin common modules</description>
      <enforcement>mandatory</enforcement>
      <verification>code-review</verification>
    </protection>
  </antiCheatProtections>

  <milestones>
    <milestone id="M1" name="Project Setup and Architecture">
      <description>Initial project setup with Kotlin Multiplatform structure</description>
      <tasks>
        <task id="T1.1" type="setup" priority="high" estimated="4h">
          <title>Initialize Kotlin Multiplatform project structure</title>
          <description>Create base Gradle project with KMP configuration for all target platforms</description>
          <requirements>
            <requirement>Kotlin 2.2+ configuration</requirement>
            <requirement>Gradle build scripts for all targets</requirement>
            <requirement>ktlint and detekt configuration</requirement>
            <requirement>Unit testing framework setup (kotlin.test)</requirement>
            <requirement>UI testing framework setup</requirement>
          </requirements>
          <deliverables>
            <deliverable>build.gradle.kts files for all modules</deliverable>
            <deliverable>gradle.properties with version catalog</deliverable>
            <deliverable>ktlint.gradle.kts and detekt.yml</deliverable>
            <deliverable>Basic project structure with common/android/ios/wasmjs modules</deliverable>
          </deliverables>
          <verification>
            <criterion>gradle build succeeds on all targets</criterion>
            <criterion>ktlint and detekt run without errors</criterion>
            <criterion>sample unit test passes on all platforms</criterion>
          </verification>
          <antiCheatChecks>
            <check>No sample/template code remains</check>
            <check>All configuration is production-ready</check>
            <check>Tests actually verify functionality</check>
          </antiCheatChecks>
        </task>

        <task id="T1.2" type="architecture" priority="high" estimated="3h">
          <title>Define common data models and interfaces</title>
          <description>Create common Kotlin data classes and interfaces based on current TypeScript models</description>
          <requirements>
            <requirement>Convert all TypeScript interfaces to Kotlin data classes</requirement>
            <requirement>Implement proper serialization (kotlinx.serialization)</requirement>
            <requirement>Define repository interfaces</requirement>
            <requirement>Create domain models separate from API models</requirement>
          </requirements>
          <dependencies>
            <dependency>T1.1</dependency>
          </dependencies>
          <deliverables>
            <deliverable>commonMain/kotlin/models/ with all data models</deliverable>
            <deliverable>commonMain/kotlin/repository/ interfaces</deliverable>
            <deliverable>commonMain/kotlin/domain/ domain models</deliverable>
            <deliverable>Comprehensive unit tests for serialization</deliverable>
          </deliverables>
          <verification>
            <criterion>All models serialize/deserialize correctly</criterion>
            <criterion>Unit tests cover all data transformations</criterion>
            <criterion>Models match current API contract</criterion>
          </verification>
          <antiCheatChecks>
            <check>No hardcoded sample data in models</check>
            <check>All models have proper validation</check>
            <check>Serialization tests use real data scenarios</check>
          </antiCheatChecks>
        </task>

        <task id="T1.3" type="architecture" priority="medium" estimated="2h">
          <title>Setup dependency injection framework</title>
          <description>Configure Koin or similar DI framework for multiplatform use</description>
          <requirements>
            <requirement>DI framework working on all platforms</requirement>
            <requirement>Module definitions for each layer</requirement>
            <requirement>Platform-specific implementations</requirement>
          </requirements>
          <dependencies>
            <dependency>T1.2</dependency>
          </dependencies>
          <deliverables>
            <deliverable>DI module definitions</deliverable>
            <deliverable>Platform-specific DI setup</deliverable>
            <deliverable>Integration tests for DI configuration</deliverable>
          </deliverables>
          <verification>
            <criterion>DI works correctly on all platforms</criterion>
            <criterion>No circular dependencies</criterion>
            <criterion>All interfaces have implementations</criterion>
          </verification>
          <antiCheatChecks>
            <check>No singleton anti-patterns</check>
            <check>Proper separation of concerns</check>
            <check>Tests verify actual injection behavior</check>
