{
  "legal_areas": {
    "property_disputes": {
      "keywords": ["fence", "boundary", "dividing fence", "neighbour dispute", "neighbor dispute", "property line", "shared fence"],
      "patterns": ["fence", "boundary", "dispute.*neighbour", "dispute.*neighbor", "dividing"],
      "authorities": ["dispute_resolution", "legislation"],
      "description": "Disputes between neighbours regarding property boundaries, fences, and related matters"
    },
    "neighbourhood_disputes": {
      "keywords": ["neighbour", "neighbor", "noise", "tree", "parking", "access", "nuisance"],
      "patterns": ["neighbour", "neighbor", "dispute.*residential", "noise.*complaint", "tree.*dispute"],
      "authorities": ["dispute_resolution", "council"],
      "description": "General disputes between neighbours including noise, trees, access rights"
    },
    "food_safety": {
      "keywords": ["food", "restaurant", "cafe", "catering", "food business", "hygiene", "food handling"],
      "patterns": ["food.*business", "restaurant", "cafe", "catering", "food.*safety", "food.*license"],
      "authorities": ["food_safety"],
      "description": "Food safety regulations, licensing, and compliance for food businesses"
    },
    "business_regulations": {
      "keywords": ["business", "license", "permit", "corporation", "company", "commercial", "trade"],
      "patterns": ["business.*license", "business.*permit", "commercial.*law", "company.*registration"],
      "authorities": ["business_support"],
      "description": "Business licensing, permits, and commercial regulations"
    },
    "property_law": {
      "keywords": ["property", "land", "real estate", "development", "planning", "zoning"],
      "patterns": ["property.*law", "real.*estate", "development.*application", "planning.*permit"],
      "authorities": ["council", "planning"],
      "description": "Property ownership, development, and planning matters"
    },
    "development_permits": {
      "keywords": ["pool", "swimming pool", "deck", "shed", "extension", "renovation", "build", "construction", "permit", "approval"],
      "patterns": ["build.*pool", "swimming.*pool", "large.*pool", "construction.*permit", "development.*permit", "building.*approval"],
      "authorities": ["council", "planning"],
      "description": "Building permits and development approvals for pools, extensions, and construction projects"
    },
    "dispute_resolution": {
      "keywords": ["dispute", "mediation", "tribunal", "conflict", "disagreement", "resolution"],
      "patterns": ["dispute.*resolution", "mediation", "tribunal", "conflict.*resolution"],
      "authorities": ["dispute_resolution"],
      "description": "General dispute resolution and mediation services"
    }
  },
  "authority_types": {
    "food_safety": {
      "name": "Food Safety Authority",
      "description": "Responsible for food safety regulations and licensing",
