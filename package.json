{
  "name": "legalease",
  "version": "1.0.0",
  "description": "AI-powered platform for navigating Australian regulatory requirements",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "services"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "encore run",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "encore build",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "encore test",
    "test:frontend": "cd frontend && npm test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "eslint services/**/*.ts",
    "lint:frontend": "cd frontend && npm run lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules frontend/node_modules services/node_modules",
    "install:all": "npm install && cd frontend && npm install"
  },
  "keywords": [
    "govhack",
    "regulatory",
    "compliance",
    "australia",
    "typescript",
    "vue",
    "encore"
  ],
  "author": "Team Democracy Sausage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codemucker/govhack_2025"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "encore.dev": "^1.46.5"
  }
}
